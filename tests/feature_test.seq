func describe(value) {
    if (value < 0) {
        return 1;
    } else if (value == 0) {
        return 2;
    }

    return 3;
}

count = 0;

while (count < 8) {
    count = count + 1;

    if (count % 2 == 0) {
        continue;
    }

    if (!(count < 7) || count == 5) {
        break;
    }

    print "odd count: " count;
}

print "describe(-3) = " describe(-3);
print "describe(0) = " describe(0);
print "describe(9) = " describe(9);
