func factorial(n) {
    if (n <= 1) {
        return 1;
    }
    result = n * factorial(n - 1);
    return result;
}

// Function to compute the sum from 1 to n
func sum_to_n(n) {
    if (n <= 0) {
        return 0;
    }
    return n + sum_to_n(n - 1);
}

// Function to calculate area of rectangle
func rectangle_area(width, height) {
    return width * height;
}

// Function to check if number is even
func is_even(num) {
    remainder = num / 2;
    if (remainder * 2 == num) {
        return 1;
    }
    return 0;
}

